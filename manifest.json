{
  "manifest_version": 3,
  "name": "JobLens – Smart Job Intelligence",
  "version": "1.0.0",
  "description": "Opportunity scores and recruiter intelligence on every job board",
  "permissions": ["storage", "alarms", "tabs", "scripting"],
  "host_permissions": [
    "https://*.naukri.com/*",
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.wellfound.com/*",
    "https://*.instahyre.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.naukri.com/*",
        "https://*.linkedin.com/jobs/*",
        "https://*.indeed.com/*",
        "https://*.wellfound.com/jobs/*",
        "https://*.instahyre.com/*"
      ],
      "js": ["src/content_scripts/detector.ts"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["src/content_scripts/overlay.ts", "assets/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
